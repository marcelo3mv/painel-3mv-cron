# .github/workflows/deploy.yml
# Repositório: marcelo3mv/painel-3mv-cron
#
# O QUE FAZ AUTOMATICAMENTE:
#   1. Baixa pedidos do Suas Vendas (API)
#   2. Injeta dados no HTML (gerar_painel.py)
#   3. Publica no GitHub Pages (painel online no celular e desktop)
#   4. Envia email de alertas para Lais, Rafaela e Marcelo (opcional)
#
# QUANDO RODA:
#   - Push em main (deploy imediato)
#   - Segunda-feira 8h BRT (atualização semanal + alertas)
#   - Quinta-feira  8h BRT (atualização semanal + alertas)
#   - Manualmente via GitHub → Actions → "Run workflow"
#
# SECRETS OPCIONAIS (GitHub → Settings → Secrets → Actions):
#   SV_TOKEN     — Suas Vendas → Configurações → API → Token (para dados ao vivo)
#   RESEND_API_KEY — resend.com → API Keys (para alertas por email)

name: 🚀 Deploy + Alertas 3MV

on:
  push:
    branches: [main]
  schedule:
    - cron: '0 11 * * 1'   # Segunda-feira 8h BRT (11h UTC)
    - cron: '0 11 * * 4'   # Quinta-feira  8h BRT (11h UTC)
  workflow_dispatch:
    inputs:
      forcar_alertas:
        description: 'Forçar envio de alertas mesmo sem pendências?'
        required: false
        default: 'false'
        type: choice
        options: ['false', 'true']

permissions:
  contents: write
  pages: write
  id-token: write

env:
  PYTHON_VERSION: '3.11'

jobs:
  # ─────────────────────────────────────────────────────────────────────────────
  # JOB 1: Baixar dados, gerar HTML e publicar no GitHub Pages
  # ─────────────────────────────────────────────────────────────────────────────
  build-and-deploy:
    name: 📦 Build + Deploy GitHub Pages
    runs-on: ubuntu-latest
    outputs:
      tem_pendencias: ${{ steps.check.outputs.tem_pendencias }}
      total_criticos: ${{ steps.check.outputs.total_criticos }}
      total_atrasados: ${{ steps.check.outputs.total_atrasados }}
      total_saldos: ${{ steps.check.outputs.total_saldos }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Setup Python ${{ env.PYTHON_VERSION }}
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Instalar dependências
        run: pip install requests openpyxl python-dateutil --quiet

      - name: 📡 Baixar pedidos do Suas Vendas
        id: sv
        env:
          SV_TOKEN: ${{ secrets.SV_TOKEN }}
        run: |
          python3 extrair_saldos.py && echo "sv_ok=true" >> $GITHUB_OUTPUT \
            || (echo "sv_ok=false" >> $GITHUB_OUTPUT && echo "⚠️ Suas Vendas falhou — usando último dados.json")

      - name: 📊 Gerar painel HTML
        run: python3 gerar_painel.py

      - name: Preparar index.html
        run: |
          cp painel_atual.html index.html
          ls -la index.html sw.js manifest.json 2>/dev/null || true

      - name: 🔍 Verificar pendências para alertas
        id: check
        run: |
          python3 - << 'PYEOF'
          import json, os, sys
          from datetime import date, timedelta

          try:
              with open('dados.json', 'r', encoding='utf-8') as f:
                  dados = json.load(f)
          except:
              sys.exit(0)

          hoje = date.today()
          peds = dados.get('pedidos_2026', [])

          criticos = sum(
              1 for p in peds
              if p.get('fatura_status') == 'Sem fatura' and p.get('data')
              and (hoje - date.fromisoformat(str(p['data'])[:10])).days > 5
          )
          atrasados = sum(
              1 for p in peds
              if p.get('fatura_status') in ('Total','Parcial') and not p.get('data_entrega') and p.get('data_fatura')
              and (hoje - (date.fromisoformat(str(p['data_fatura'])[:10]) + timedelta(days=7))).days > 0
          )
          saldos = sum(1 for p in peds if p.get('fatura_status') == 'Parcial')
          tem = 'true' if (criticos + atrasados) > 0 else 'false'

          with open(os.environ['GITHUB_OUTPUT'], 'a') as f:
              f.write(f"tem_pendencias={tem}\n")
              f.write(f"total_criticos={criticos}\n")
              f.write(f"total_atrasados={atrasados}\n")
              f.write(f"total_saldos={saldos}\n")

          print(f"Críticos: {criticos} | Atrasados: {atrasados} | Saldos: {saldos}")
          PYEOF

      - name: 🚀 Commit e push do painel atualizado
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add index.html dados.json painel_atual.html 2>/dev/null || true
          git diff --cached --quiet && echo "(sem mudanças)" || \
            git commit -m "auto: atualiza painel $(date +'%d/%m/%Y %H:%M BRT')" && \
            git push origin main

      - name: ✅ Painel publicado
        run: |
          echo "✅ Painel publicado em: https://marcelo3mv.github.io/painel-3mv-cron/"
          echo "✅ Também disponível em: https://raw.githack.com/marcelo3mv/painel-3mv-cron/main/index.html"

  # ─────────────────────────────────────────────────────────────────────────────
  # JOB 2: Alertas automáticos por email (Resend API — opcional)
  # ─────────────────────────────────────────────────────────────────────────────
  alertas:
    name: 📧 Alertas automáticos
    needs: [build-and-deploy]
    runs-on: ubuntu-latest
    if: |
      (github.event_name == 'schedule' || github.event.inputs.forcar_alertas == 'true')
      && (needs.build-and-deploy.outputs.tem_pendencias == 'true' || github.event.inputs.forcar_alertas == 'true')

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: 📧 Enviar email de alertas (Resend)
        env:
          RESEND_API_KEY: ${{ secrets.RESEND_API_KEY }}
          CRITICOS: ${{ needs.build-and-deploy.outputs.total_criticos }}
          ATRASADOS: ${{ needs.build-and-deploy.outputs.total_atrasados }}
          SALDOS: ${{ needs.build-and-deploy.outputs.total_saldos }}
          PAINEL_URL: 'https://marcelo3mv.github.io/painel-3mv-cron/'
        run: |
          python3 - << 'PYEOF'
          import os, json, urllib.request, urllib.error
          from datetime import date

          api_key = os.environ.get('RESEND_API_KEY', '')
          if not api_key:
              print("⚠️ RESEND_API_KEY não configurada — email não enviado (opcional)")
              exit(0)

          criticos  = int(os.environ.get('CRITICOS', '0'))
          atrasados = int(os.environ.get('ATRASADOS', '0'))
          saldos    = int(os.environ.get('SALDOS', '0'))
          painel    = os.environ.get('PAINEL_URL', '')
          hoje      = date.today().strftime('%d/%m/%Y')
          total     = criticos + atrasados

          html_body = f"""<!DOCTYPE html><html><body style="font-family:sans-serif;max-width:600px;margin:0 auto;padding:20px">
          <div style="background:#0556AD;padding:16px 20px;border-radius:8px 8px 0 0">
            <h1 style="color:#fff;margin:0;font-size:20px">🚨 Alertas 3MV — {hoje}</h1>
            <p style="color:rgba(255,255,255,0.8);margin:4px 0 0;font-size:13px">{total} pendência(s) crítica(s)</p>
          </div>
          <div style="background:#fff;border:1px solid #e2e8f0;border-top:0;padding:20px;border-radius:0 0 8px 8px">
            <p>🔴 Sem fatura críticos: <b>{criticos}</b></p>
            <p>📦 Entregas atrasadas: <b>{atrasados}</b></p>
            <p>📋 Saldos parciais: <b>{saldos}</b></p>
            <a href="{painel}" style="color:#0556AD;font-weight:700">Abrir Painel 3MV</a>
          </div></body></html>"""

          for nome, email in [("Lais","adm@3mvrepresentacao.com"),("Rafaela","adm1@3mvrepresentacao.com"),("Marcelo","marcelo@3mvrepresentacao.com")]:
              payload = json.dumps({"from":"alertas@3mvrepresentacao.com","to":[f"{nome} <{email}>"],
                  "subject":f"[3MV] 🚨 {total} pendência(s) — {hoje}","html":html_body}).encode()
              req = urllib.request.Request("https://api.resend.com/emails",data=payload,
                  headers={"Authorization":f"Bearer {api_key}","Content-Type":"application/json"},method="POST")
              try:
                  with urllib.request.urlopen(req) as r:
                      print(f"✅ Email para {email}: HTTP {r.status}")
              except urllib.error.HTTPError as e:
                  print(f"❌ {email}: {e.code} — {e.read().decode()[:100]}")
          PYEOF
